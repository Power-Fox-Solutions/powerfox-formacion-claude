# EditorConfig — unifica estilo entre editores y entre alumnos.
# Docs: https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Permitimos trailing whitespace en markdown porque dos espacios al final
# de una línea generan un salto de línea visible.
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab
